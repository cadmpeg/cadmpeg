# Fuzzer seed corpora are raw libFuzzer inputs, not source. Several targets
# prefix a strategy byte before the JSON payload, so files under these paths
# are binary even when named *.json and must never be formatted.
crates/cadmpeg-fuzz/seeds/
crates/cadmpeg-fuzz/corpus/
crates/cadmpeg-fuzz/artifacts/
seeds/

# Golden snapshot trees are byte-compared by tests. A formatter rewrite is
# corruption, not style: every file under a golden directory must keep the
# exact bytes its harness wrote, including pretty-JSON layout.
crates/*/tests/golden/
