ISO-10303-21;
HEADER;
FILE_DESCRIPTION(('AP242 tessellation'),'2;1');
FILE_NAME('mesh','2026-07-14T00:00:00',('cadmpeg'),('cadmpeg'),'cadmpeg-step','','');
FILE_SCHEMA(('AP242_MANAGED_MODEL_BASED_3D_ENGINEERING_MIM_LF'));
ENDSEC;
DATA;
#1=(LENGTH_UNIT() NAMED_UNIT(*) SI_UNIT(.MILLI.,.METRE.));
#2=(GEOMETRIC_REPRESENTATION_CONTEXT(3) GLOBAL_UNIT_ASSIGNED_CONTEXT((#1)) REPRESENTATION_CONTEXT('model','3D'));
#3=COORDINATES_LIST('triangle coordinates',3,((0.,0.,0.),(10.,0.,0.),(0.,10.,0.)));
#4=TRIANGULATED_FACE('triangle',#3,3,((0.,0.,1.)),$,(),((1,2,3)));
#5=TESSELLATED_SHAPE_REPRESENTATION('mesh',(#4),#2);
#6=COORDINATES_LIST('strip coordinates',4,((0.,0.,0.),(10.,0.,0.),(0.,10.,0.),(10.,10.,0.)));
#7=COMPLEX_TRIANGULATED_FACE('strip and fan',#6,4,((1.,0.,0.),(0.,1.,0.),(0.,0.,1.),(0.,0.,-1.)),$,(4,3,2,1),((1,2,3,4)),((1,2,4)));
#8=TESSELLATED_SHAPE_REPRESENTATION('complex mesh',(#7),#2);
ENDSEC;
END-ISO-10303-21;
