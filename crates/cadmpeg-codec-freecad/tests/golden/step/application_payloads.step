ISO-10303-21;
HEADER;
FILE_DESCRIPTION(('CAD model exported by cadmpeg'),'2;1');
FILE_NAME('cadmpeg_model','1970-01-01T00:00:00',(''),(''),'cadmpeg-step','cadmpeg','');
FILE_SCHEMA(('AUTOMOTIVE_DESIGN { 1 0 10303 214 1 1 1 1 }'));
ENDSEC;
DATA;
#1 = ( LENGTH_UNIT() NAMED_UNIT(*) SI_UNIT(.MILLI.,.METRE.) );
#2 = ( NAMED_UNIT(*) PLANE_ANGLE_UNIT() SI_UNIT($,.RADIAN.) );
#3 = ( NAMED_UNIT(*) SI_UNIT($,.STERADIAN.) SOLID_ANGLE_UNIT() );
#4 = UNCERTAINTY_MEASURE_WITH_UNIT(LENGTH_MEASURE(0.000001),#1,'distance_accuracy_value','maximum model space distance');
#5 = ( GEOMETRIC_REPRESENTATION_CONTEXT(3) GLOBAL_UNCERTAINTY_ASSIGNED_CONTEXT((#4)) GLOBAL_UNIT_ASSIGNED_CONTEXT((#1,#2,#3)) REPRESENTATION_CONTEXT('Context','3D') );
#6 = CARTESIAN_POINT('',(1.,2.,3.));
#7 = CARTESIAN_POINT('',(4.,5.,6.));
#8 = CARTESIAN_POINT('',(-1.,0.,2.));
#9 = GEOMETRIC_CURVE_SET('',(#6,#7,#8));
#10 = CARTESIAN_POINT('',(0.,0.,0.));
#11 = DIRECTION('',(0.,0.,1.));
#12 = DIRECTION('',(1.,0.,0.));
#13 = AXIS2_PLACEMENT_3D('',#10,#11,#12);
#14 = APPLICATION_CONTEXT('automotive design');
#15 = APPLICATION_PROTOCOL_DEFINITION('international standard','automotive_design',2000,#14);
#16 = PRODUCT_CONTEXT('',#14,'mechanical');
#17 = PRODUCT('cadmpeg_model','cadmpeg_model','',(#16));
#18 = PRODUCT_DEFINITION_FORMATION('','',#17);
#19 = PRODUCT_DEFINITION_CONTEXT('part definition',#14,'design');
#20 = PRODUCT_DEFINITION('design','',#18,#19);
#21 = PRODUCT_DEFINITION_SHAPE('','',#20);
#22 = SHAPE_REPRESENTATION('',(#9,#13),#5);
#23 = SHAPE_DEFINITION_REPRESENTATION(#21,#22);
ENDSEC;
END-ISO-10303-21;
